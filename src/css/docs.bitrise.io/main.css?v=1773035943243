  /* -------- Brand Colors -------- */

  --brand-neutral-white: #ffffff;
  --brand-neutral-light: #dbdbdb;
  --brand-neutral-dark: #7c7c7c;
  --brand-neutral-black: #000000;

  --brand-purple-lightest: #f6eaff;
  --brand-purple-light: #deb4ff;
  --brand-purple-mid: #6a3c98;
