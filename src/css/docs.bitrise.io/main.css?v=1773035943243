  --brand-yellow-mid: #ffc500;

  --brand-orage-light: #ffd7c9;
  --brand-orange-mid: #ffa17f;
  --brand-orange-dark: #ff4400;

  --brand-red-light: #ffd0ec;
  --brand-red-mid: #ff9cd8;
