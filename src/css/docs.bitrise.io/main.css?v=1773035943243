  --brand-blue-lightest: #d7f5ff;
  --brand-blue-light: #88e3ff;
  --brand-blue-mid: #005fbe;
  --brand-blue-dark: #11258e;

  --brand-teal-lightest: #dbfffd;
  --brand-teal-light: #95ffec;
  --brand-teal-mid: #10c0c0;
